# === Backend GOA Kombucha ===

# Port d'écoute du backend
SERVER_HOST=0.0.0.0
PORT=8788

# --- Easybeer (Basic Auth) ---
# Identifiant + mot de passe d'API GÉNÉRÉS dans le compte Easybeer (cf. EASYBEER.md).
EASYBEER_USERNAME=
EASYBEER_PASSWORD=
EASYBEER_API_TARGET=https://api.easybeer.fr
# Coupe un appel bloqué pour ne pas figer la file Easybeer entière.
EASYBEER_TIMEOUT_MS=20000

# --- Firebase ---
# Dev : FIREBASE_EMULATORS=true → émulateurs locaux (Auth 9100, Firestore 8180),
# aucune clé de service nécessaire. Démarrer avec `npm run dev:emulators` (racine).
FIREBASE_EMULATORS=true
FIREBASE_AUTH_EMULATOR_HOST=localhost:9100
FIRESTORE_EMULATOR_HOST=localhost:8180
FIREBASE_STORAGE_EMULATOR_HOST=localhost:9200
FIREBASE_PROJECT_ID=demo-goa-kombucha
# Nouveau projet : <project-id>.firebasestorage.app ; ancien : <project-id>.appspot.com
FIREBASE_STORAGE_BUCKET=
# Prod Cloud Run : FIREBASE_EMULATORS=false, sans clé JSON (identité du service).
# Hors Google Cloud uniquement : chemin facultatif vers une clé locale.
GOOGLE_APPLICATION_CREDENTIALS=

# --- Dev ---
# true => l'auth est court-circuitée (utilisateur de test injecté). NE JAMAIS activer en prod.
# Inutile avec les émulateurs (préférer un vrai login sur l'émulateur Auth).
AUTH_DISABLED=false
# idClient Easybeer utilisé par l'utilisateur de test quand AUTH_DISABLED=true
DEV_EASYBEER_ID_CLIENT=588074

# URL du front autorisée (CORS)
WEB_ORIGIN=http://localhost:5173

# Synchro périodique Easybeer → cache Firestore, en minutes (0 = désactivée).
# Le job est « ban-aware » (ne tape pas l'API pendant un ban) et verrouillé
# (pas de chevauchement). Reco prod : 15–30 min (ou Cloud Scheduler → POST
# /api/admin/sync). En dev : laisser 0 et synchroniser à la main depuis l'admin.
SYNC_INTERVAL_MINUTES=0
# Secret du endpoint Cloud Scheduler (32 caractères minimum en production).
SCHEDULER_SECRET=

# Cloud Run / Cloud Tasks (production uniquement).
CLOUD_TASKS_PROJECT_ID=
CLOUD_TASKS_LOCATION=europe-west1
CLOUD_TASKS_QUEUE=easybeer-sync
CLOUD_RUN_SERVICE_URL=
# Secret aléatoire d'au moins 32 caractères, stocké dans Secret Manager.
TASKS_SECRET=

# Auto-guérison du cache à la consultation (stale-while-revalidate).
# Le cache courant reste servi pendant le rafraîchissement. Ces seuils doivent
# rester strictement inférieurs à PRIX_CACHE_MAX_AGE_MINUTES.
CATALOGUE_AUTO_REFRESH_MINUTES=30
PRIX_AUTO_REFRESH_MINUTES=30
CACHE_AUTO_REFRESH_COOLDOWN_MINUTES=10
CLIENTS_AUTO_REFRESH_MINUTES=30
COMMANDES_AUTO_REFRESH_MINUTES=10
# Seuil strict avant envoi d'une commande (>= au refresh prix).
PRIX_COMMANDE_MAX_AGE_MINUTES=60
# Garde-fou dur : au-delà, une commande est bloquée si aucune autre source de
# prix fraîche n'est disponible.
PRIX_CACHE_MAX_AGE_MINUTES=2160

# true (défaut) : les commandes partent en DEVIS Easybeer (dev/test, réversible).
# false (prod) : vraies commandes fermes.
COMMANDE_EST_DEVIS=true

# --- Email d'invitation (SMTP) ---
# Sans SMTP_HOST, l'envoi est désactivé : on retombe sur le lien copiable.
# OVH : hôte pro1.mail.ovh.net, port 587 (STARTTLS). Port 465 => SMTP_SECURE=true.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=GOA Kombucha <contact@goa-kombucha.fr>
# SMTP_REPLY_TO=
# SMTP_SECURE=false
INVITE_BASE_URL=http://localhost:5173/activer
# Validité du lien d'invitation (jours), usage unique.
INVITE_EXPIRES_DAYS=14
# URL absolue du logo GOA (PNG) pour l'email ; vide => wordmark texte.
# INVITE_LOGO_URL=
