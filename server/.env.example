# === Backend GOA Kombucha ===

# Port d'écoute du backend
PORT=8788

# --- Easybeer (Basic Auth) ---
# Identifiant + mot de passe d'API GÉNÉRÉS dans le compte Easybeer (cf. EASYBEER.md).
EASYBEER_USERNAME=
EASYBEER_PASSWORD=
EASYBEER_API_TARGET=https://api.easybeer.fr

# --- Firebase ---
# Dev : FIREBASE_EMULATORS=true → émulateurs locaux (Auth 9099, Firestore 8080),
# aucune clé de service nécessaire. Démarrer avec `npm run dev:emulators` (racine).
FIREBASE_EMULATORS=true
FIREBASE_PROJECT_ID=demo-goa-kombucha
# Prod : FIREBASE_EMULATORS=false + chemin vers la clé de compte de service.
GOOGLE_APPLICATION_CREDENTIALS=

# --- Dev ---
# true => l'auth est court-circuitée (utilisateur de test injecté). NE JAMAIS activer en prod.
# Inutile avec les émulateurs (préférer un vrai login sur l'émulateur Auth).
AUTH_DISABLED=false
# idClient Easybeer utilisé par l'utilisateur de test quand AUTH_DISABLED=true
DEV_EASYBEER_ID_CLIENT=588074

# URL du front autorisée (CORS)
WEB_ORIGIN=http://localhost:5173

# Synchro périodique Easybeer → cache Firestore, en minutes (0 = désactivée).
# Le job est « ban-aware » (ne tape pas l'API pendant un ban) et verrouillé
# (pas de chevauchement). Reco prod : 15–30 min (ou Cloud Scheduler → POST
# /api/admin/sync). En dev : laisser 0 et synchroniser à la main depuis l'admin.
SYNC_INTERVAL_MINUTES=0

# true (défaut) : les commandes partent en DEVIS Easybeer (dev/test, réversible).
# false (prod) : vraies commandes fermes.
COMMANDE_EST_DEVIS=true

# --- Email d'invitation (SMTP) ---
# Sans SMTP_HOST, l'envoi est désactivé : on retombe sur le lien copiable.
# OVH : hôte pro1.mail.ovh.net, port 587 (STARTTLS). Port 465 => SMTP_SECURE=true.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=GOA Kombucha <contact@goa-kombucha.fr>
# SMTP_REPLY_TO=
# SMTP_SECURE=false
INVITE_BASE_URL=http://localhost:5173/activer
# Validité du lien d'invitation (jours), usage unique.
INVITE_EXPIRES_DAYS=14
# URL absolue du logo GOA (PNG) pour l'email ; vide => wordmark texte.
# INVITE_LOGO_URL=
