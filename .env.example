# === Identifiants API Easybeer (Basic Auth) ===
# ATTENTION : ce ne sont PAS votre email/mot de passe de connexion à app.easybeer.fr.
# Ce sont l'identifiant + le mot de passe d'API à GÉNÉRER dans votre compte Easybeer
# (voir le guide de connexion fourni avec le POC).
#
# Copiez ce fichier en `.env.local` et renseignez vos valeurs de test.
# `.env.local` est ignoré par git et NE DOIT JAMAIS être commité.

EASYBEER_USERNAME=identifiant_api_de_test
EASYBEER_PASSWORD=mot_de_passe_api_de_test

# Cible de l'API (laisser tel quel sauf indication contraire)
EASYBEER_API_TARGET=https://api.easybeer.fr
