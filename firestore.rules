rules_version = '2';

// Tout accès Firestore passe par le serveur Hono (Admin SDK, qui ignore ces
// règles). Le navigateur ne lit JAMAIS Firestore en direct → tout est refusé.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
