# Copier en `.env.local` (gitignoré).

# --- Dev : émulateur Firebase Auth local (npm run dev:emulators à la racine) ---
VITE_FIREBASE_EMULATOR=true
VITE_FIREBASE_AUTH_EMULATOR_URL=http://localhost:9100

# --- Prod : config web du vrai projet Firebase (console → paramètres du projet) ---
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_APP_ID=
